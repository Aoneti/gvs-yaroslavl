# GitHub Pages / Netlify / Cloudflare Pages custom response headers
# (#23 fix): явные Cache-Control директивы предотвращают ситуацию, когда
# браузер кеширует старый data.json / geo.json с новым gvs-core.js.

# HTML-страницы — не кешировать (всегда свежие)
/*.html
  Cache-Control: no-cache, must-revalidate

# Core JS-файл с бизнес-логикой: не кешировать (может обновляться с данными)
/gvs-core.js
  Cache-Control: no-cache, must-revalidate

# Данные — не кешировать (обновляются в течение сезона)
/data.json
  Cache-Control: no-cache, must-revalidate

/geo.json
  Cache-Control: no-cache, must-revalidate

# Прикладные скрипты страниц — не кешировать (зависят от gvs-core.js)
/app-index.js
  Cache-Control: no-cache, must-revalidate

/app-map.js
  Cache-Control: no-cache, must-revalidate

/analytics.js
  Cache-Control: no-cache, must-revalidate

/ui-widgets.js
  Cache-Control: no-cache, must-revalidate

/theme-init.js
  Cache-Control: no-cache, must-revalidate

# Vendor JS/CSS — стабильны (версия зафиксирована), кешируем на 1 год
/vendor/*
  Cache-Control: public, max-age=31536000, immutable

# Шрифты — стабильны, кешируем на 1 год
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Стили — не кешировать (связаны с разметкой)
/styles.css
  Cache-Control: no-cache, must-revalidate
